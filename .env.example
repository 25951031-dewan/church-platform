# Local dev: APP_ENV=local APP_DEBUG=true
# Production server: APP_ENV=production APP_DEBUG=false
APP_NAME="Church Platform"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://church-platform.test
APP_KEY=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=church_platform
DB_USERNAME=root
DB_PASSWORD=

# Redis — REDIS_PREFIX prevents key collisions on shared Redis instances
CACHE_DRIVER=redis
SESSION_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_PREFIX=church_
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

QUEUE_CONNECTION=database

BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_SCHEME=https
PUSHER_HOST=
PUSHER_PORT=443

SCOUT_DRIVER=database

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@church-platform.test
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=local

# LiveKit — Sprint 8.5 (voice/video calls, self-hosted $6 VPS)
LIVEKIT_HOST=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/auth/oauth/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/api/v1/auth/oauth/facebook/callback"
